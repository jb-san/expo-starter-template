{
  "name": "expo-starter-template",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android -d",
    "ios": "expo run:ios -d",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "update-project": "node ./scripts/update-project.js && expo-doctor",
    "clean:ios": "rm -rf ios/",
    "clean:node_modules": "rm -rf node_modules/",
    "clean:android": "rm -rf android/",
    "clean:cache": "rm -rf $TMPDIR/react-* && rm -rf $TMPDIR/metro-* && rm -rf .expo/ && rm -rf .expo-shared/",
    "clean:all": "npm run clean:node_modules && npm run clean:ios && npm run clean:android && npm run clean:cache && npm run clean:watchman",
    "clean:watchman": "watchman watch-del-all",
    "nuke": "rm -rf package-lock.json && npm run clean:all",
    "postinstall": "patch-package"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^expo-modules-core$": "<rootDir>/node_modules/expo-modules-core",
      "^@react-native-async-storage/async-storage$": "<rootDir>/node_modules/@react-native-async-storage/async-storage/jest/async-storage-mock"
    }
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-vector-icons/material-icons": "^13.1.2",
    "expo": "^56.0.8",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "nativewind": "^4.2.3",
    "patch-package": "^8.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "tailwindcss": "^3.4.16"
  },
  "devDependencies": {
    "@expo/config-plugins": "~56.0.0",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~56.0.4",
    "expo-doctor": "^1.18.19",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.4",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}