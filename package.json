{
  "name": "expo-starter-template",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android -d",
    "ios": "expo run:ios -d",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "update-project": "node ./scripts/update-project.js && expo-doctor",
    "clean:ios": "rm -rf ios/",
    "clean:node_modules": "rm -rf node_modules/",
    "clean:android": "rm -rf android/",
    "clean:cache": "rm -rf $TMPDIR/react-* && rm -rf $TMPDIR/metro-* && rm -rf .expo/ && rm -rf .expo-shared/",
    "clean:all": "npm run clean:node_modules && npm run clean:ios && npm run clean:android && npm run clean:cache && npm run clean:watchman",
    "clean:watchman": "watchman watch-del-all",
    "nuke": "rm -rf package-lock.json && npm run clean:all"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^expo-modules-core$": "<rootDir>/node_modules/expo-modules-core",
      "^@react-native-async-storage/async-storage$": "<rootDir>/node_modules/@react-native-async-storage/async-storage/jest/async-storage-mock"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.0",
    "expo": "~55.0.17",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.28",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "tailwindcss": "^3.4.16"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "expo-doctor": "^1.18.19",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.16",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.3.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
